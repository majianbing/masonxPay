# ── Database ─────────────────────────────────────────────────────────────────
DB_NAME=mason_x_pay
DB_USERNAME=pay_app_user
DB_PASSWORD=password123

# ── JWT ───────────────────────────────────────────────────────────────────────
# REQUIRED: generate a random 32+ character secret
# e.g.  openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-32-char-secret

# ── URLs ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
PAY_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Stripe (optional — leave blank to disable payment processing) ─────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email (optional — leave blank to disable invite emails) ──────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ── Encryption (required if using stored credentials) ────────────────────────
# e.g.  openssl rand -base64 32
ENCRYPTION_KEY=
# ── High-throughput profile ──────────────────────────────────────────────────
PAYMENT_SHARD_COUNT=64

# Optional infra is disabled for the lightweight live-demo path.
# Enable these only when Kafka/Redis are available, or use .env.preview.
KAFKA_OUTBOX_ENABLED=false
KAFKA_WEBHOOK_CONSUMER_ENABLED=false
KAFKA_PAYMENT_PROJECTION_ENABLED=false
WEBHOOK_OUTBOX_POLLER_ENABLED=true
PAYMENT_PROJECTION_BACKFILL_ENABLED=false
REDIS_HOT_PATH_ENABLED=false
REDIS_RATE_LIMIT_ENABLED=false
REDIS_IDEMPOTENCY_CACHE_ENABLED=false
REDIS_PROVIDER_HEALTH_CACHE_ENABLED=false
REDIS_HEALTH_ENABLED=false

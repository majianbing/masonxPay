# Copy to secret.env (gitignored) before running kustomize/apply. This
# generator is fine for a first EKS smoke test; for real production, replace
# it with the External Secrets Operator syncing from AWS Secrets Manager
# instead of a checked-out-of-git local file — see README.md in this dir.
#   cp secret.env.example secret.env
# Generate real values with: openssl rand -base64 32

DB_PASSWORD=
JWT_SECRET=
ENCRYPTION_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MAIL_USERNAME=
MAIL_PASSWORD=

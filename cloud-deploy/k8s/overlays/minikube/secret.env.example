# Copy to secret.env (gitignored) before running kustomize/apply.
#   cp secret.env.example secret.env
# Generate real values with: openssl rand -base64 32

DB_PASSWORD=password123
JWT_SECRET=change-me-to-a-random-32-char-secret
ENCRYPTION_KEY=vspZvnzhIfkspgW2GAeZidicAiVsoe2qd1fm7jktat8=

# Optional — leave blank to disable. Blank values still need the key present
# so the secretGenerator emits an (empty) entry the app config expects.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MAIL_USERNAME=
MAIL_PASSWORD=

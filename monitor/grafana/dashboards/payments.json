{
  "uid": "masonxpay-payments",
  "title": "MasonXPay — Payments",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": [],
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },

    {
      "id": 2,
      "type": "timeseries",
      "title": "Payment Volume (confirmations/s)",
      "description": "Rate of payment intents reaching a terminal state after confirmation.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(payment_intent_confirmed_total[2m])) by (provider, status)",
          "legendFormat": "{{provider}} / {{status}}"
        }
      ]
    },

    {
      "id": 3,
      "type": "timeseries",
      "title": "Charge Latency p50 / p95 (by provider)",
      "description": "Wall-clock time of individual charge calls to each provider.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(payment_charge_latency_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p50 {{provider}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(payment_charge_latency_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p95 {{provider}}"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Overall Success Rate (last 30 min)",
      "description": "Fraction of confirmed intents that succeeded.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.80 },
              { "color": "green",  "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(payment_intent_confirmed_total{status='SUCCEEDED'}[30m])) / sum(rate(payment_intent_confirmed_total[30m]))",
          "legendFormat": "Success Rate"
        }
      ]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Failover Events (last 1h)",
      "description": "Number of times the retry loop moved to a secondary connector.",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(payment_intent_failover_total[1h])",
          "legendFormat": "Failovers"
        }
      ]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Refunds Initiated (last 1h)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(payment_refund_initiated_total[1h])",
          "legendFormat": "Refunds"
        }
      ]
    },

    {
      "id": 7,
      "type": "stat",
      "title": "Manual Captures (last 1h)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(payment_capture_attempted_total[1h])",
          "legendFormat": "Captures"
        }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Failure Breakdown by Code",
      "description": "Rate of failed intents broken down by provider failure code.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 1 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(payment_intent_confirmed_total{status='FAILED'}[5m])) by (failure_code, provider)",
          "legendFormat": "{{provider}} / {{failure_code}}"
        }
      ]
    },

    {
      "id": 9,
      "type": "row",
      "title": "Connector Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false
    },

    {
      "id": 10,
      "type": "bargauge",
      "title": "30-min Success Rate by Connector",
      "description": "Rolling 30-minute success rate per connector account. Updated every 5 minutes by ConnectorHealthService.",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.80 },
              { "color": "green",  "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "connector_success_rate",
          "legendFormat": "{{label}} ({{provider}})"
        }
      ]
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Connector Success Rate Trend",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "connector_success_rate",
          "legendFormat": "{{label}} ({{provider}})"
        }
      ]
    },

    {
      "id": 12,
      "type": "row",
      "title": "Operations",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "collapsed": false
    },

    {
      "id": 13,
      "type": "timeseries",
      "title": "Webhook Outbox Queue Depth",
      "description": "Unprocessed outbox events. Spikes are normal during bursts; sustained growth indicates a delivery problem.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red",    "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "payment_outbox_queue_depth",
          "legendFormat": "Queue Depth"
        }
      ]
    },

    {
      "id": 14,
      "type": "timeseries",
      "title": "Stale PROCESSING Intents",
      "description": "Payment intents stuck in PROCESSING for more than 30 minutes. Should be near zero; the reconciliation job resolves these every 5 minutes.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "payment_stale_processing_count",
          "legendFormat": "Stale Intents"
        }
      ]
    },

    {
      "id": 15,
      "type": "stat",
      "title": "Webhook Deliveries Processed (last 1h)",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(payment_webhook_outbox_processed_total[1h])",
          "legendFormat": "Deliveries"
        }
      ]
    },

    {
      "id": 16,
      "type": "stat",
      "title": "Stale Intents Resolved (last 1h)",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(payment_stale_resolved_total[1h])",
          "legendFormat": "{{status}}"
        }
      ]
    },

    {
      "id": 17,
      "type": "row",
      "title": "Kafka",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "collapsed": false
    },

    {
      "id": 18,
      "type": "stat",
      "title": "Kafka Broker Up",
      "description": "Prometheus scrape health for Kafka JMX exporter.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "up{job='kafka-jmx'}",
          "legendFormat": "Kafka"
        }
      ]
    },

    {
      "id": 19,
      "type": "stat",
      "title": "Kafka Outbox Queue",
      "description": "Outbox events waiting for Kafka publication.",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "payment_kafka_outbox_queue_depth",
          "legendFormat": "Queue"
        }
      ]
    },

    {
      "id": 20,
      "type": "stat",
      "title": "Oldest Kafka Outbox Event",
      "description": "Age of the oldest event waiting for Kafka publication.",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 300 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "payment_kafka_outbox_oldest_age_seconds",
          "legendFormat": "Oldest"
        }
      ]
    },

    {
      "id": 21,
      "type": "stat",
      "title": "Under-Replicated Partitions",
      "description": "Should be zero in local single-node mode.",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "kafka_server_replicamanager_underreplicatedpartitions",
          "legendFormat": "Under Replicated"
        }
      ]
    },

    {
      "id": 22,
      "type": "timeseries",
      "title": "Kafka Outbox Publish Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(payment_kafka_outbox_published_total[5m])) by (event_type)",
          "legendFormat": "published {{event_type}}"
        },
        {
          "expr": "rate(payment_kafka_outbox_failed_total[5m])",
          "legendFormat": "failed"
        }
      ]
    },

    {
      "id": 23,
      "type": "timeseries",
      "title": "Kafka Broker Throughput",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(kafka_server_brokertopicmetrics_bytesinpersec_total[5m])",
          "legendFormat": "bytes in"
        },
        {
          "expr": "rate(kafka_server_brokertopicmetrics_bytesoutpersec_total[5m])",
          "legendFormat": "bytes out"
        }
      ]
    }

  ]
}

    {
      "id": 26,
      "type": "timeseries",
      "title": "payment_read_models Sequential vs Index Scans",
      "description": "Sequential scan rate climbing relative to index scans means a query/filter combination isn't using the existing indexes \u2014 usually fixable with a targeted index before reaching for partitioning or OpenSearch.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 57
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"

{
  "uid": "masonxpay-payments",
  "title": "MasonXPay \u2014 Payments",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Payment Volume",
      "description": "Confirmed payment intents by provider and status. Uses total counters so manual/local tests remain visible after the request burst.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(payment_intent_confirmed_total) by (provider, status) or on() vector(0)",
          "legendFormat": "{{provider}} / {{status}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Charge Latency p50 / p95 (by provider)",
      "description": "Wall-clock time of individual charge calls to each provider.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(payment_charge_latency_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p50 {{provider}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(payment_charge_latency_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p95 {{provider}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Overall Success Rate",
      "description": "Current success ratio from confirmed-intent counters. Connector health panels still show rolling 30-minute account health.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.8
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "(sum(payment_intent_confirmed_total{status=\"SUCCEEDED\"}) / clamp_min(sum(payment_intent_confirmed_total), 1)) or vector(0)",
          "legendFormat": "Success Rate"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Failover Events (last 1h)",

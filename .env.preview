# Preview is a local production-like profile. Values are intentionally local-only.
SPRING_PROFILES_ACTIVE=preview

DB_NAME=paygateway_preview
DB_USERNAME=pay_preview_user
DB_PASSWORD=preview_password_123
PREVIEW_DB_NAME=paygateway_preview
PREVIEW_DB_USERNAME=pay_preview_user
PREVIEW_DB_PASSWORD=preview_password_123

JWT_SECRET=preview-local-jwt-secret-change-before-real-prod-256-bit

# ── Database ─────────────────────────────────────────────────────────────────
DB_NAME=mason_x_pay
DB_USERNAME=pay_app_user
DB_PASSWORD=password123

# ── JWT ───────────────────────────────────────────────────────────────────────
# REQUIRED: generate a random 32+ character secret
# e.g.  openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-32-char-secret

# ── URLs ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
PAY_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── High-throughput profile ──────────────────────────────────────────────────
PAYMENT_SHARD_COUNT=64

# Kafka / Redis — two modes:
#
# Lightweight (default, docker compose up --build):
#   All Kafka and Redis features off. Only Postgres + gateway + dashboard run.
#   WEBHOOK_OUTBOX_POLLER_ENABLED=true keeps webhook delivery working via DB polling.
#
# Full infra (docker compose --profile infra up --build):
#   Set the Kafka and Redis vars below to true. IMPORTANT: set
#   WEBHOOK_OUTBOX_POLLER_ENABLED=false — the DB poller and Kafka webhook worker
#   both deliver webhooks; running both causes duplicate delivery.
#
KAFKA_OUTBOX_ENABLED=false
KAFKA_WEBHOOK_CONSUMER_ENABLED=false
KAFKA_PAYMENT_PROJECTION_ENABLED=false
WEBHOOK_OUTBOX_POLLER_ENABLED=true
PAYMENT_PROJECTION_BACKFILL_ENABLED=false
REDIS_HOT_PATH_ENABLED=false
REDIS_RATE_LIMIT_ENABLED=false
REDIS_IDEMPOTENCY_CACHE_ENABLED=false
REDIS_PROVIDER_HEALTH_CACHE_ENABLED=false
REDIS_HEALTH_ENABLED=false

# ── H7 benchmark simulator provider ──────────────────────────────────────────
# Disabled by default. docker-compose.bench.yml enables it for k6 confirm/refund flows.
NEXT_PUBLIC_ENABLE_SIMULATOR_PROVIDER=false
PROVIDER_SIMULATOR_ENABLED=false
PROVIDER_SIMULATOR_BASE_LATENCY_MS=25
PROVIDER_SIMULATOR_JITTER_MS=25
PROVIDER_SIMULATOR_FAILURE_RATE=0.0
PROVIDER_SIMULATOR_TIMEOUT_RATE=0.0
SIMULATOR_SUCCESS_RATE_PERCENT=95

# ── Stripe (optional — leave blank to disable payment processing) ─────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email (optional — leave blank to disable invite emails) ──────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ── Encryption (required if using stored credentials) ────────────────────────
# e.g.  openssl rand -base64 32
ENCRYPTION_KEY=vspZvnzhIfkspgW2GAeZidicAiVsoe2qd1fm7jktat8=

# ── MR5-B: gateway → rail bridge ─────────────────────────────────────────────
# Set RAIL_ENABLED=true when running docker compose --profile rail (or --profile infra).
# Requires rail-service and rail-simulator containers to be up.
RAIL_ENABLED=false
RAIL_BASE_URL=http://rail-service:8081
RAIL_RESOLVED_TOPIC=rail.payment.resolved
RAIL_RESOLVED_CONSUMER_GROUP_ID=gateway-rail-resolved

# ── RAG support assistant (optional; requires docker compose --profile ai) ───
AI_ASSISTANT_ENABLED=false
AI_SERVICE_BASE_URL=http://ai-service:8090
# Set a strong shared secret and RAG_REQUIRE_AUTH=true for the ai-service profile.
# Keep ai-service private and do not expose it directly.
AI_SERVICE_AUTH_TOKEN=
RAG_REQUIRE_AUTH=false
AI_ASSISTANT_REQUEST_LIMIT_PER_WINDOW=60
AI_ASSISTANT_TOKEN_LIMIT_PER_WINDOW=12000
AI_ASSISTANT_BUDGET_WINDOW_SECONDS=3600
# Answer generation. Default `local` = no external AI (deterministic extractive answers).
# Set RAG_MODEL_PROVIDER=openai + OPENAI_API_KEY to generate answers with a frontier model.
# Only approved retrieved docs + the question are sent to the provider.
RAG_MODEL_PROVIDER=local
RAG_MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=
